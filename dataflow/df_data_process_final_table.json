{
	"name": "df_data_process_final_table",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "stg_events_current",
						"type": "DatasetReference"
					},
					"name": "Hoofdtabel"
				},
				{
					"dataset": {
						"referenceName": "api_ref_myid",
						"type": "DatasetReference"
					},
					"name": "MyIDFilter"
				},
				{
					"dataset": {
						"referenceName": "raw_verzekeraar31",
						"type": "DatasetReference"
					},
					"name": "Verzekeraar31"
				},
				{
					"dataset": {
						"referenceName": "raw_verzekeraar_N741H742",
						"type": "DatasetReference"
					},
					"name": "VerzekeraarH742N741"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ref_csv_events_export",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "Niet31"
				},
				{
					"name": "Wel31"
				},
				{
					"name": "join2"
				},
				{
					"name": "union1"
				},
				{
					"name": "MaatschappijID"
				},
				{
					"name": "H742N741"
				},
				{
					"name": "join5"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "NieuweKolommen"
				},
				{
					"name": "FilterMessage0"
				},
				{
					"name": "FilterMyID"
				},
				{
					"name": "window2"
				},
				{
					"name": "filter2"
				},
				{
					"name": "VerzekeraarMyAnd"
				}
			],
			"scriptLines": [
				"parameters{",
				"     p_week as string",
				"}",
				"source(output(",
				"          event_id as string,",
				"          message as string,",
				"          user_identity as string,",
				"          gim_function as string,",
				"          gim_function_number as integer,",
				"          week as integer,",
				"          jaar as integer,",
				"          my_aand as string,",
				"          confirmation_at as string,",
				"          functie_id as string,",
				"          my_aand_user as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> Hoofdtabel",
				"source(output(",
				"          filter as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> MyIDFilter",
				"source(output(",
				"          Column_1 as string,",
				"          Column_2 as string,",
				"          Column_3 as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> Verzekeraar31",
				"source(output(",
				"          Oud as string,",
				"          Nieuw as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> VerzekeraarH742N741",
				"Hoofdtabel filter(gim_function_number != 31) ~> Niet31",
				"Hoofdtabel filter(gim_function_number == 31 && my_aand != 'H742' && my_aand != 'N741') ~> Wel31",
				"Wel31, VerzekeraarMyAnd join(my_aand == Code,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"MaatschappijID, join2, join5 union(byName: true)~> union1",
				"Niet31 derive(maatschappij_ID = toString(gim_function_number)) ~> MaatschappijID",
				"Hoofdtabel filter(gim_function_number == 31 && (my_aand == 'H742' || my_aand == 'N741')) ~> H742N741",
				"H742N741, VerzekeraarH742N741 join(startsWith(my_aand_user, Oud),",
				"     joinType:'cross',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join5",
				"derivedColumn5 select(mapColumn(",
				"          event_id,",
				"          message,",
				"          user_identity,",
				"          gim_function,",
				"          gim_function_number,",
				"          week,",
				"          jaar,",
				"          my_aand,",
				"          confirmation_at,",
				"          functie_id,",
				"          my_aand_user,",
				"          maatschappij_ID,",
				"          Code,",
				"          Oud,",
				"          Nieuw,",
				"          {naam maatschappij},",
				"          middenstuk,",
				"          KantoorId,",
				"          GebruikerId,",
				"          Systeemhuis,",
				"          {KantoorId+GebruikId},",
				"          role_group",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"FilterMessage0 derive({KantoorId+GebruikId} = replace(concat(KantoorId, '_', GebruikerId), '-', '_'),",
				"          role_group = concat( toString({Systeemhuis}),     '_',     toString(KantoorId) ),",
				"          functie_id = concat('\\t', toString(functie_id))) ~> derivedColumn5",
				"union1 derive(middenstuk = split(gim_function, \".\")[2],",
				"          KantoorId = split(user_identity, '_')[2],",
				"          GebruikerId = case(\r",
				"  split(user_identity,'_')[4] != '',\r",
				"  split(user_identity,'_')[3] + '-' + split(user_identity,'_')[4],\r",
				"  split(user_identity,'_')[3]\r",
				"),",
				"          Systeemhuis = split(user_identity, '_')[1]) ~> NieuweKolommen",
				"FilterMyID filter(!(",
				"  (event_id == '73' || event_id == '74')",
				"  && message == '0'",
				") && event_id != '43') ~> FilterMessage0",
				"NieuweKolommen, MyIDFilter exists(maatschappij_ID == filter,",
				"     negate:true,",
				"     broadcast: 'auto')~> FilterMyID",
				"Verzekeraar31 window(over(Column_2),",
				"     asc(Column_2, true),",
				"     rn = rowNumber()) ~> window2",
				"window2 filter(!(Column_2== 'N741' || Column_2== 'H742') && rn == 1) ~> filter2",
				"filter2 select(mapColumn(",
				"          Code = Column_2,",
				"          maatschappij_ID = Column_3",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> VerzekeraarMyAnd",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:[(concat('export_week_', $p_week, '.csv'))],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}